# Garden Protector — Pi environment.
# Copy to `.env` (gitignored) and fill in. Loaded by hardware/portal.py and
# hardware/gateway.py, and by systemd (EnvironmentFile) once deploy/install.sh runs.

# REQUIRED: admin passcode for the LAN portal at http://raspberrypi.local
# Anyone on your network who enters this gets FULL admin control of the garden.
GP_ADMIN_PASSCODE=change-me

# Fastly Compute edge base URL the Pi talks to (dashboard data + the safety path).
GP_BACKEND=https://your-service.edgecompute.app

# Tenancy / auth — match what gp-provision issued. Defaults are fine for a single
# garden (the `default` garden is tokenless).
GP_GARDEN_ID=default
GP_DEVICE_ID=default
GP_NODE_ID=default
GP_GARDEN_TOKEN=

# OPTIONAL: viewer password for the EDGE (compute-app) dashboard. Provisioned to
# the edge by `make provision-viewer` (Part B). Leave blank to keep the edge
# dashboard open (view-only either way).
GP_VIEWER_PASSCODE=

# OPTIONAL portal tuning (sensible defaults shown).
# GP_PORTAL_SECRET=          # explicit cookie-signing key (else derived from the passcode)
# GP_SESSION_TTL=43200       # admin session lifetime in seconds (default 12h)
# Where the portal binds. Default is :80 (clean URL). If Pi-hole / another server
# already owns :80, use a free port, e.g.:
# GP_PORTAL_LISTEN=0.0.0.0:8080
